---
import { getCollection } from 'astro:content';
import Nav from '@components/layout/Nav.astro';
import CondimentProducts from '@components/product/CondimentProducts.astro';
import HoneyProducts from '@components/product/HoneyProducts.astro';
import SeedsProducts from '@components/product/SeedsProducts.astro';
import Layout from '@layouts/Layout.astro';
import type { Product } from '@models/product';

const productsData = await getCollection('products');
const products: Product[] = productsData.flatMap((entry) => entry.data);
---

<Layout footerBg="bg-landak-teal">
  <Nav isHome={false} />

  <!-- Page wrapper with deep teal background -->
  <div class='min-h-screen bg-gradient-to-b from-[#0d2e24] via-landak-teal to-[#0d2e24]'>

    <!-- Hero header -->
    <header class='relative flex flex-col items-center text-center pt-32 pb-16 px-4 overflow-hidden'>
      <!-- Decorative background glow -->
      <div class='absolute inset-0 pointer-events-none'>
        <div class='absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-landak-light/5 rounded-full blur-3xl'></div>
      </div>

      <span class='relative px-5 py-1.5 mb-6 text-xs font-bold uppercase tracking-[0.25em] rounded-full bg-landak-light/10 border border-landak-light/20 text-landak-light'>
        Catálogo Completo
      </span>

      <h1 class='relative text-5xl md:text-7xl font-bold font-bellota italic text-white leading-tight'>
        Nuestros <span class='text-landak-light'>Productos</span>
      </h1>

      <p class='relative mt-4 text-white/60 text-base md:text-lg font-light max-w-xl'>
        Descubre el sabor auténtico de la naturaleza con Apiario Landak
      </p>

      <p class='relative mt-4 text-landak-yellow font-light text-sm md:text-base max-w-2xl'>
        Envase de vidrio premium 100% nuevo y reutilizable · Tapas y sellos libres de BPA
      </p>

      <!-- Decorative divider -->
      <div class='relative mt-10 w-24 h-px bg-gradient-to-r from-transparent via-landak-light/50 to-transparent'></div>
    </header>

    <!-- Categories -->
    <section class='flex flex-col gap-y-16 px-4 pb-24 w-full max-w-7xl mx-auto'>
      <HoneyProducts products={products} />
      <CondimentProducts products={products} />
      <SeedsProducts products={products} />
    </section>
  </div>
</Layout>
