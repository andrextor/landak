---
import { Image } from 'astro:assets';
import defaultProduct from '@assets/images/products/default_product.webp';
import type { ImageMetadata } from 'astro';

interface Props {
  imagePath: string;
  addClass: string | null;
}

const { imagePath, addClass } = Astro.props;
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/products/*.{jpeg,jpg,png,gif,webp}',
);

const img = !images[imagePath] ? defaultProduct : images[imagePath]();
---
<Image
  src={img}
  alt='Imagen de producto Apiario Landak'
  class:list={["flex", addClass]}
  widths={[240, 480, 720, 1024]}
  sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
  loading='lazy'
  decoding='async'
/>