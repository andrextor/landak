---
import Nav from '@components/layout/Nav.astro';
import ContactButton from '@components/ui/ContactButton.astro';
import { SITE_CONFIG } from '@constants/index';
---

<header
  id="home"
  class='relative bg-[url(/src/assets/images/hero.webp)] bg-cover bg-[65%_center] md:bg-[60%_center] h-[100vh] md:h-screen rounded-b-[3rem] overflow-hidden shadow-base transition-all duration-700 font-arsenal'
>
  {/* Desktop: gradient covers left 55%, fades before the product jar */}
  <div class="hidden md:block absolute inset-0 bg-gradient-to-r from-landak-teal/95 via-landak-teal/70 to-transparent" style="background: linear-gradient(to right, #04303b 0%, rgba(4,48,59,0.80) 38%, rgba(4,48,59,0.30) 58%, transparent 72%);"></div>

  {/* Desktop: subtle green luminance from bottom-left for brand color */}
  <div class="hidden md:block absolute inset-0" style="background: radial-gradient(ellipse at 5% 95%, rgba(130,199,92,0.18) 0%, transparent 55%);"></div>

  {/* Mobile: strong bottom-up gradient so text is readable */}
  <div class="md:hidden absolute inset-0" style="background: linear-gradient(to top, #04303b 0%, rgba(4,48,59,0.88) 35%, rgba(4,48,59,0.50) 58%, rgba(4,48,59,0.15) 100%);"></div>

  {/* Shared: top vignette for nav contrast */}
  <div class="absolute inset-x-0 top-0 h-40" style="background: linear-gradient(to bottom, rgba(4,48,59,0.65) 0%, transparent 100%);"></div>

  {/* Amber color cast on image area for warmth */}
  <div class="absolute inset-0" style="background: radial-gradient(ellipse at 80% 45%, rgba(255,181,69,0.10) 0%, transparent 50%);"></div>
  
  <Nav />
  
  <div class='relative z-10 flex flex-col justify-center h-full px-6 md:px-16 max-w-7xl mx-auto pt-20'>
    <div class="flex flex-col gap-y-8 max-w-2xl text-left">
      
      <div class="space-y-6 animate-fade-in-up">
        {/* Sleek top badge */}
        <div class="inline-flex items-center gap-x-3 px-4 py-2 border border-landak-light/30 rounded-full bg-landak-teal/40 backdrop-blur-md shadow-sm w-fit">
          <span class="w-2 h-2 rounded-full bg-landak-yellow animate-pulse"></span>
          <span class="text-xs md:text-sm text-landak-light font-bold uppercase tracking-widest">Orgullo del Valle del Cauca</span>
        </div>

        <h1 class='text-6xl md:text-8xl lg:text-[140px] font-bold font-bellota italic text-white leading-none tracking-tighter drop-shadow-lg left-shift'>
          {SITE_CONFIG.name}
        </h1>
        
        <p class='text-xl md:text-3xl text-landak-yellow font-light tracking-[0.1em] uppercase pl-1'>
          Agroecología Integral
        </p>
      </div>

      <div class="animate-fade-in-up" style="animation-delay: 150ms;">
        <p class='text-lg md:text-xl font-light leading-relaxed text-white/80 pl-1 border-l-2 border-landak-light/50 py-2'>
          Un emprendimiento familiar vinculado al <strong class="text-white font-medium">Consejo Comunitario Afro Vallecito</strong>. Miel orgánica cruda producida en las montañas PEDET de Pradera, entre los 1.500 y 1.800 msnm.
        </p>
      </div>

      <div class='flex flex-col sm:flex-row items-center sm:items-start gap-6 mt-6 animate-fade-in-up pl-1' style="animation-delay: 300ms;">
        <a
          href='#products'
          class='w-full sm:w-auto relative group overflow-hidden rounded-full px-10 py-4 text-base font-bold bg-landak-primary text-white transition-all duration-500 hover:scale-[1.02] active:scale-95 shadow-[0_8px_30px_rgba(12,101,17,0.3)]'
        >
          <span class="relative z-10 flex items-center gap-2">Explorar Catálogo <span class="group-hover:translate-x-1 transition-transform">→</span></span>
          <div class="absolute inset-0 h-full w-full bg-gradient-to-r from-landak-light to-landak-primary opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </a>
        
        <ContactButton className="!border-white/20 hover:!border-white !bg-transparent hover:!bg-white/10 backdrop-blur-sm text-white/90 hover:text-white" />
      </div>

    </div>
  </div>

  <div class="absolute bottom-12 left-1/2 transform -translate-x-1/2 flex flex-col items-center gap-3 animate-fade-in-up scroll-hide" style="animation-delay: 500ms;">
    <div class="flex items-center gap-4 cursor-pointer group" onclick="document.getElementById('products').scrollIntoView({behavior: 'smooth'})">
      <div class="w-8 h-12 rounded-full border-2 border-white/30 flex justify-center p-2 group-hover:border-landak-yellow transition-colors">
        <div class="w-1 h-3 bg-landak-yellow rounded-full animate-bounce"></div>
      </div>
      <span class="text-white/60 text-xs uppercase tracking-[0.2em] font-bold group-hover:text-white transition-colors">Descubre más</span>
    </div>
  </div>

  <script>
    // Hide the scroll hint when the user scrolls down
    const hideOnScroll = () => {
      if (window.scrollY > 100) {
        document.body.classList.add('scrolled');
      } else {
        document.body.classList.remove('scrolled');
      }
    };
    window.addEventListener('scroll', hideOnScroll);
  </script>
  <style>
    .scroll-hide {
      opacity: 1;
      transition: opacity 0.4s ease;
    }
    .scrolled .scroll-hide {
      opacity: 0;
      pointer-events: none;
    }
  </style>
</header>
<style>
  .left-shift {
    margin-left: -4px; /* Optically align the huge serif italic text */
  }
</style>
