---
import CardProductDetail from '@components/product/CardProductDetail.astro';
import type { Product } from '@models/product';

interface Props {
  products: Product[];
}

const { products } = Astro.props;

const filtered = products.filter((p) => p.category === 'Miel');
---

{filtered.length > 0 && (
  <div class='relative flex flex-col gap-y-8 p-8 rounded-3xl bg-gradient-to-br from-[#0f3d2e] to-[#0a2a1f] border border-landak-light/15 shadow-2xl shadow-black/30 overflow-hidden'>
    <!-- Decorative glow -->
    <div class='absolute -top-16 -right-16 w-64 h-64 rounded-full bg-landak-light/8 blur-3xl pointer-events-none'></div>

    <!-- Category header -->
    <div class='relative flex items-center gap-x-4'>
      <div class='w-1.5 h-10 rounded-full bg-landak-light shadow-[0_0_16px_rgba(130,199,92,0.6)]'></div>
      <div class='flex flex-col'>
        <span class='text-landak-light/60 text-xs uppercase tracking-[0.2em] font-semibold'>Colección</span>
        <h2 class='text-landak-light text-2xl md:text-3xl font-bold italic tracking-tight'>Linea de Miel</h2>
      </div>
    </div>

    <!-- Divider -->
    <div class='h-px bg-gradient-to-r from-landak-light/20 via-landak-light/10 to-transparent'></div>

    <!-- Products grid -->
    <div class='grid grid-cols-1 lg:grid-cols-2 gap-6'>
      {filtered.map((product) => (
        <CardProductDetail {...product} />
      ))}
    </div>
  </div>
)}