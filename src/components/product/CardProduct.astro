---
import WhatsAppIcon from '@components/icons/WhatsAppIcon.astro';
import ProductImage from '@components/ui/ProductImage.astro';
import type { Product } from '@models/product';
import { formatCOP } from '@utils/format';
import { getWhatsAppUrl } from '@utils/whatsapp';

interface Props extends Product {}

const { slug, title, description, amount, available, image_path, category } = Astro.props;

const whatsAppUrl = getWhatsAppUrl({ title, slug });
const formattedAmount = amount ? formatCOP(amount) : null;
---

<article class='group relative flex flex-col w-64 rounded-2xl overflow-hidden bg-white/5 border border-white/10 backdrop-blur-sm shadow-xl shadow-black/20 transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl hover:shadow-landak-primary/20 hover:border-white/20'>

  <!-- Image wrapper with zoom effect -->
  <div class='relative overflow-hidden aspect-square bg-white/5'>
    <ProductImage
      imagePath={`/src/assets/images/products/${image_path}.webp`}
      addClass='w-full h-full object-cover transition-transform duration-500 group-hover:scale-110'
    />

    <!-- Availability badge -->
    <div class={`absolute top-3 right-3 flex items-center gap-x-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider border ${available ? 'bg-black/70 border-landak-light text-landak-light' : 'bg-black/70 border-red-400 text-red-400'}`}>
      <span class={`size-1.5 rounded-full shrink-0 ${available ? 'bg-landak-light shadow-[0_0_8px_rgba(130,199,92,1)]' : 'bg-red-400 shadow-[0_0_8px_rgba(248,113,113,1)]'}`}></span>
      {available ? 'Disponible' : 'Agotado'}
    </div>

    <!-- Category pill -->
    {category && (
      <div class='absolute top-3 left-3 px-2.5 py-1 rounded-full text-[10px] font-semibold uppercase tracking-wider bg-black/40 border border-white/10 text-white/70 backdrop-blur-md'>
        {category}
      </div>
    )}

    <!-- Price overlay on hover -->
    <div class='absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-center pb-3'>
      {formattedAmount && (
        <span class='text-landak-yellow font-bold text-xl drop-shadow-md'>{formattedAmount}</span>
      )}
    </div>
  </div>

  <!-- Content -->
  <div class='flex flex-col flex-1 p-4 gap-y-3'>
    <!-- Title & price -->
    <div class='flex flex-col gap-y-1'>
      <h4 class='text-base font-bold text-white leading-snug line-clamp-1'>{title}</h4>
      {formattedAmount && (
        <span class='text-landak-yellow font-semibold text-sm group-hover:hidden'>{formattedAmount}</span>
      )}
    </div>

    <p class='text-xs text-white/60 leading-relaxed line-clamp-3 flex-1'>{description}</p>

    <!-- Actions -->
    <div class='flex flex-col gap-y-2 pt-1'>
      <a
        href={whatsAppUrl}
        target='_blank'
        rel='noopener noreferrer'
        class='flex items-center justify-center gap-x-2 py-2.5 px-4 rounded-xl bg-[#25D366] text-white text-xs font-bold tracking-wide transition-all duration-200 hover:brightness-110 hover:scale-[1.02] active:scale-95 shadow-md shadow-[#25D366]/20'
      >
        <WhatsAppIcon className='w-4 h-4 shrink-0' />
        Pedir por WhatsApp
      </a>

      <a
        href={`/products/${slug}`}
        class='flex items-center justify-center gap-x-1.5 py-2 px-4 rounded-xl border border-white/15 text-white/70 text-xs font-medium tracking-wide transition-all duration-200 hover:border-white/30 hover:text-white hover:bg-white/5 active:scale-95'
      >
        Ver detalles
        <span class='text-[10px] transition-transform duration-200 group-hover:translate-x-0.5'>→</span>
      </a>
    </div>
  </div>
</article>