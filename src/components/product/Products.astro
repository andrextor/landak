---
import { getCollection } from 'astro:content';
import CardProduct from '@components/product/CardProduct.astro';

const productsCollection = await getCollection('products');
const allProducts = productsCollection.flatMap((entry) => entry.data);
---

<section
  id='products'
  class='flex flex-col items-center bg-landak-teal text-white py-20 px-4 rounded-b-[3rem] relative z-20 -mt-12'
>
  <div class="flex flex-col items-center mb-16 text-center">
    <h2 class='text-landak-light text-4xl md:text-6xl font-bold font-bellota italic'>Nuestros Productos</h2>
    <div class="w-32 h-1.5 bg-landak-yellow mt-4 rounded-full shadow-[0_0_15px_rgba(232,228,84,0.4)]"></div>
    <p class="mt-6 text-landak-yellow/80 max-w-2xl font-light text-lg">
      Descubre la pureza de nuestras montañas en cada una de nuestras presentaciones cuidadosamente seleccionadas.
    </p>
  </div>

  <div class="w-full md:max-w-10xl">
    <div class="flex items-center justify-center relative mb-10">
      <div class="absolute inset-x-0 h-px bg-gradient-to-r from-transparent via-landak-light/30 to-transparent"></div>
      <span class="relative px-6 py-2 bg-landak-teal border border-landak-light/20 rounded-full text-landak-light font-arsenal uppercase tracking-[0.2em] text-sm shadow-[0_0_15px_rgba(130,199,92,0.1)]">Nuestra Selección</span>
    </div>

    <div class='flex flex-wrap justify-center gap-6'>
      {allProducts.map((product) => (
        <CardProduct {...product} />
      ))}
    </div>
  </div>

  <div class="mt-20">
    <a
      href="/products"
      class="group relative inline-flex items-center gap-x-3 px-10 py-4 bg-landak-light text-landak-teal font-bold text-xl rounded-full transition-all hover:bg-white hover:scale-105 active:scale-95 shadow-xl shadow-landak-primary/20"
    >
      Explorar Catálogo Completo
      <span class="text-2xl transition-transform group-hover:translate-x-1">→</span>
    </a>
  </div>
</section>
